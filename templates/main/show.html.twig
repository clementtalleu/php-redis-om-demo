{% extends 'main/base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
    <div class="mb-6">
        <a class="inline-flex items-center text-indigo-600 hover:text-indigo-800 font-medium transition" href="{{ path('book_list') }}">
            <svg class="mr-2" xmlns="http://www.w3.org/2000/svg" height="16" width="14" viewBox="0 0 448 512">
                <path fill="currentColor" d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.2 288 416 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-306.7 0L214.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/>
            </svg>
            Retour au catalogue
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="md:flex">
            <div class="md:w-1/3 bg-gray-100 flex justify-center items-center p-8">
                <img class="max-h-[400px] shadow-2xl rounded-lg"
                     src="https://placehold.co/400x600/6366f1/ffffff?text={{ book.title|url_encode }}"
                     alt="Couverture de {{ book.title }}">
            </div>

            <div class="md:w-2/3 p-8 lg:p-12">
                <div class="flex items-center space-x-3 mb-6">
                    <div class="rounded-full py-1 px-3 flex items-center {% if book.enabled %}bg-green-100 text-green-700{% else %}bg-red-100 text-red-700{% endif %}">
                        <div class="rounded-full h-2 w-2 {% if book.enabled %}bg-green-500{% else %}bg-red-500{% endif %} mr-2"></div>
                        <p class="uppercase text-[10px] font-bold tracking-wider">
                            {{ book.enabled ? 'Disponible' : 'Indisponible' }}
                        </p>
                    </div>
                    <span class="text-gray-400 text-sm">Réf: {{ book.id|slice(0, 8) }}</span>
                </div>

                <h1 class="text-4xl font-extrabold text-gray-900 mb-2 leading-tight">
                    {{ book.title }}
                </h1>

                <p class="text-xl text-indigo-600 font-medium mb-8">
                    Par {{ book.authorId }} {# Ici on affichera le nom de l'auteur plus tard #}
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-gray-100 pt-8">
                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Catégorie</h4>
                        <p class="text-lg font-semibold text-gray-800">{{ book.categoryId }}</p>
                    </div>

                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Prix</h4>
                        <p class="text-lg font-semibold text-gray-800">{{ book.price }} €</p>
                    </div>

                    <div class="md:col-span-2">
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-2">Description</h4>
                        <p class="text-gray-600 leading-relaxed">
                            {{ book.description|default('Aucune description disponible pour cet ouvrage.') }}
                        </p>
                    </div>

                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Publié le</h4>
                        <p class="text-lg font-semibold text-gray-800">{{ book.publishedAt|date('d/m/Y') }}</p>
                    </div>
                </div>

                <div class="mt-10 flex space-x-4">
                    <button class="flex-1 bg-indigo-600 text-white font-bold py-3 px-6 rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                        Emprunter l'ouvrage
                    </button>
                    <a href="{{ path('admin_book_edit', {id: book.id}) }}" class="bg-gray-100 text-gray-600 py-3 px-6 rounded-xl hover:bg-gray-200 transition font-medium">
                        Modifier
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-12">
        <h3 class="text-2xl font-bold mb-6 text-gray-800">Commentaires lecteurs</h3>
        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <p class="text-gray-500 italic text-center py-4">Aucun commentaire pour le moment. Soyez le premier à donner votre avis !</p>
        </div>
    </div>
{% endblock %}
