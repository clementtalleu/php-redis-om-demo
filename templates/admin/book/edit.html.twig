{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ book.title }}{% endblock %}

{% block body %}
    <div class="max-w-2xl mx-auto">
        <div class="mb-4">
            <a href="{{ path('admin_book_show', {'id': book.id}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium">
                &larr; Annuler et retourner à la fiche
            </a>
        </div>

        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="bg-indigo-600 px-6 py-4 flex justify-between items-center">
                <h2 class="text-xl font-semibold text-white">Modifier le livre</h2>
                <span class="text-indigo-200 text-xs">ID: #{{ book.id }}</span>
            </div>


            {{ form_start(form, {'attr': {'class': 'p-6 space-y-6'}}) }}


            <div>
                {{ form_label(form.title, 'Titre de l\'ouvrage', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    {{ form_label(form.author, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.author, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>
                <div>
                    {{ form_label(form.category, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.category, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    {{ form_label(form.price, 'Prix (€)', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.price, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>
                <div>
                    {{ form_label(form.publishedAt, 'Date de publication', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.publishedAt, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>
            </div>
            <div>
                {{ form_label(form.bookEnum, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.bookEnum, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
            </div>
            <div>
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2', 'rows': '4'}}) }}
            </div>

            <div class="flex items-center bg-gray-50 p-3 rounded-md">
                {{ form_widget(form.enabled, {'attr': {'class': 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded'}}) }}
                {{ form_label(form.enabled, 'Rendre visible sur le catalogue', {'label_attr': {'class': 'ml-2 block text-sm text-gray-900'}}) }}
            </div>

            <div class="pt-4 grid grid-cols-1 md:grid-cols-2 gap-6">
                <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition">
                    Mettre à jour les informations
                </button>
            {{ form_end(form) }}

            {% if book.enabled == false %}
                <form method="post" action="{{ path('admin_book_delete', {'id': book.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce livre ?');">
                    <button class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 transition">
                        Supprimer le livre
                    </button>
                </form>
            {% else %}
                <p class="text-xs text-gray-500 italic flex items-center justify-center">
                    Désactivez le livre pour pouvoir le supprimer.
                </p>
            {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
