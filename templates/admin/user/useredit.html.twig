{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ user.name }}{% endblock %}

{% block body %}
    <div class="max-w-2xl mx-auto">
        {# Bouton Retour #}
        <div class="mb-4">
            <a href="{{ path('user', {'id': user.id}) }}" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium">
                &larr; Annuler et retourner à la liste
            </a>
        </div>

        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="bg-indigo-600 px-6 py-4 flex justify-between items-center">
                <h2 class="text-xl font-semibold text-white">Modifier l'utilisateur</h2>
                <span class="text-indigo-200 text-xs">ID: #{{ user.id }}</span>
            </div>


            {{ form_start(form, {'attr': {'class': 'p-6 space-y-6'}}) }}


            <div>
                {{ form_label(form.name, 'Nom Prénom', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
            </div>

                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>


                <div>
                    {{ form_label(form.age, 'Age', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.age, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2'}}) }}
                </div>



            <div class="pt-4 grid grid-cols-1 md:grid-cols-2 gap-6">
                <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition">
                    Mettre à jour les informations
                </button>
            </div>
                {{ form_end(form) }}

        </div>
    </div>
{% endblock %}
