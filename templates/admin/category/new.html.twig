{% extends 'base.html.twig' %}

{% block title %}Nouvelle Catégorie{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto bg-white shadow-md rounded-lg overflow-hidden">
        <div class="bg-indigo-600 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Catégorie</h2>
        </div>

        {{ form_start(form, {'attr': {'class': 'p-6 space-y-4'}}) }}
        <div>
            {{ form_label(form.category, 'Nom de la catégorie', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.category, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 border p-2', 'placeholder': 'Ex: Science-Fiction'}}) }}
        </div>

        <div class="pt-2 flex space-x-3">
            <button type="submit" class="flex-1 bg-indigo-600 text-white py-2 px-4 rounded hover:bg-indigo-700 transition font-medium">
                Enregistrer
            </button>
            <a href="#" class="flex-1 text-center py-2 px-4 border border-gray-300 rounded text-gray-600 hover:bg-gray-50 transition">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
